    "questions": [
        {
            "type": "theory",
            "question": "adb command to install a apk file if multiple devices are connected",
            "answer": "<div>&nbsp;adb devices</div><div><div>List of devices attached</div><div>40dd5226&nbsp; &nbsp; &nbsp; &nbsp; device</div><div>ZY223ZL8J8&nbsp; &nbsp; &nbsp; device</div></div><div><br></div><div><span style=\"color:oklab(0.314057 -0.0203846 -0.0629088)\">adb -s &lt;device_serial&gt; install path/to/app.apk</span></div><div><div><br></div><div>Examples:</div><div><font style=\"color:rgb(15, 23, 42)\"><span>adb -s 40dd5226 install \"D:\\Users\\admin\\Documents\\DigitalTwin\\app\\build\\outputs\\apk\\debug\\app-debug.apk\"</span></font></div><div><span style=\"color:oklab(0.314057 -0.0203846 -0.0629088)\">adb -s emulator-5554 install app-debug.apk</span></div></div><div><span style=\"color:oklab(0.314057 -0.0203846 -0.0629088)\"><br></span></div><div><h2 style=\"color:rgb(39, 37, 30);background-color:color(srgb 0.980392 0.972549 0.960784);font-weight:530\">If you want to install on all connected devices</h2><p style=\"color:rgb(39, 37, 30);background-color:color(srgb 0.980392 0.972549 0.960784);font-weight:430\">On Linux/macOS:</p><div style=\"color:rgb(39, 37, 30);background-color:color(srgb 0.980392 0.972549 0.960784);font-weight:430\"><pre><div style=\"color:rgb(214, 213, 212);background-color:rgba(39, 26, 0, 0.035)\"><div><div style=\"background-color:color(srgb 0.980392 0.972549 0.960784)\"><div style=\"background-color:rgba(39, 26, 0, 0.035)\"></div></div></div><div><div><div style=\"color:rgba(39, 37, 30, 0.65);background-color:rgba(39, 26, 0, 0.07)\">bash</div></div><div><span style=\"color:rgb(77, 77, 76);background-color:transparent\"><code><span style=\"background-color:transparent\"><span style=\"color:rgb(137, 89, 168);font-weight:bolder\">for</span><span> </span><span style=\"color:rgb(200, 40, 41)\">device</span><span> </span><span style=\"color:rgb(137, 89, 168);font-weight:bolder\">in</span><span> </span><span style=\"color:rgb(200, 40, 41)\">$(</span><span style=\"color:rgb(200, 40, 41)\">adb devices </span><span style=\"color:rgb(200, 40, 41)\">|</span><span style=\"color:rgb(200, 40, 41)\"> </span><span>awk</span><span style=\"color:rgb(200, 40, 41)\"> </span><span style=\"color:rgb(113, 140, 0)\">'NR&gt;1 &amp;&amp; $2==\"device\" {print $1}'</span><span style=\"color:rgb(200, 40, 41)\">)</span><span>;</span><span> </span><span style=\"color:rgb(137, 89, 168);font-weight:bolder\">do</span><span>\n</span></span><span style=\"background-color:transparent\"><span>  adb -s </span><span style=\"color:rgb(113, 140, 0)\">\"</span><span style=\"color:rgb(200, 40, 41)\">$device</span><span style=\"color:rgb(113, 140, 0)\">\"</span><span> </span><span>install</span><span> app-debug.apk\n</span></span><span style=\"background-color:transparent\"><span></span><span style=\"color:rgb(137, 89, 168);font-weight:bolder\">done</span></span></code></span></div></div></div></pre></div><p style=\"color:rgb(39, 37, 30);background-color:color(srgb 0.980392 0.972549 0.960784);font-weight:430\">On Windows PowerShell:</p><div style=\"color:rgb(39, 37, 30);background-color:color(srgb 0.980392 0.972549 0.960784);font-weight:430\"><pre><div style=\"color:rgb(214, 213, 212);background-color:rgba(39, 26, 0, 0.035)\"><div><div style=\"background-color:color(srgb 0.980392 0.972549 0.960784)\"><div style=\"background-color:rgba(39, 26, 0, 0.035)\"></div></div></div><div><div><div style=\"color:rgba(39, 37, 30, 0.65);background-color:rgba(39, 26, 0, 0.07)\">powershell</div></div><div><span style=\"color:rgb(77, 77, 76);background-color:transparent\"><code><span style=\"background-color:transparent\"><span>adb devices </span><span>|</span><span> </span><span>Select-String</span><span> </span><span style=\"color:rgb(113, 140, 0)\">\"device$\"</span><span> </span><span>|</span><span> </span><span>ForEach-Object</span><span> </span><span>{</span><span>\n</span></span><span style=\"background-color:transparent\"><span>  </span><span style=\"color:rgb(200, 40, 41)\">$serial</span><span> = </span><span>(</span><span style=\"color:rgb(200, 40, 41)\">$_</span><span> </span><span>-</span><span>split </span><span style=\"color:rgb(113, 140, 0)\">\"\\s+\"</span><span>)</span><span>[</span><span>0</span><span>]</span><span>\n</span></span><span style=\"background-color:transparent\"><span>  adb </span><span>-</span><span>s </span><span style=\"color:rgb(200, 40, 41)\">$serial</span><span> install app-debug</span><span>.</span><span>apk\n</span></span><span style=\"background-color:transparent\"><span></span><span>}</span></span></code></span></div></div></div></pre></div></div><div><span style=\"color:oklab(0.314057 -0.0203846 -0.0629088)\"><br></span></div>"
        }
    ]
}
